# Kerio Connect API settings for kerio_anonymizer.py.
# Copy this file to .env and edit values for your lab.
# Do not commit .env with real credentials.

# Kerio Connect Admin API JSON-RPC endpoint.
# Default Kerio Connect admin HTTPS port is usually 4040.
KERIO_API_URL=https://kerio.example.local:4040/admin/api/jsonrpc/

# Kerio account allowed to read/export logs through the Admin API.
# Example only. Replace with your own Kerio API user.
KERIO_API_USER=admin@example.local

# Kerio API password.
# Example only. Replace with your real password in .env, not in this file.
KERIO_API_PASSWORD=change-me

# Kerio log to export.
# Common Connect log names include: config, debug, error, mail, security, spam, warning.
KERIO_LOG_NAME=mail

# First line and number of lines to export.
# 0 means start at the beginning. Keep count at or below the API limit of 50000 lines.
KERIO_LOG_FROM_LINE=0
KERIO_LOG_COUNT_LINES=50000

# Set to true only for lab systems with self-signed certificates.
# Keep false when Kerio uses a trusted TLS certificate.
KERIO_API_INSECURE=false

# Optional local copy of the raw log downloaded from the API before anonymization.
# Leave empty to avoid saving the raw source log.
KERIO_SAVE_RAW=
